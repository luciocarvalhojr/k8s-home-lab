{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "argocd": {
    "enabled": true,
    "fileMatch": [
      "bootstrap/argocd/.*\\.yaml$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "apps/.*\\.yaml$",
      "infrastructure/.*\\.yaml$",
      "identity/.*\\.yaml$",
      "bootstrap/.*\\.yaml$"
    ]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ]
}
